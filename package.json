{
  "name": "agi-model-factory",
  "version": "8.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "fast-jwt": ">=6.2.4",
      "fast-uri": ">=3.1.2",
      "brace-expansion": ">=5.0.6"
    }
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "concurrently -n api,web -c cyan,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm --prefix apps/web-ui run dev",
    "dev:api": "npm --prefix apps/local-api run dev",
    "build": "npm --prefix apps/web-ui run build",
    "db:init": "node scripts/init-db.js",
    "db:doctor": "node scripts/db-doctor.js",
    "db:doctor:strict": "node scripts/db-doctor.js --strict",
    "db:migrate:status": "node scripts/db-migrate-status.js",
    "db:migrate:new": "node scripts/new-migration.js",
    "lint": "eslint \"apps/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:fix": "eslint \"apps/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"apps/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,css,json}\"",
    "typecheck": "npm --prefix apps/local-api run typecheck && npm --prefix apps/web-ui run typecheck",
    "authorization:dryrun:validate": "node scripts/authorization-dry-run-validation.mjs",
    "authorization:dryrun:roundtrip": "node scripts/authorization-db-roundtrip-validation.mjs",
    "secret:scan": "node scripts/secret-scan.mjs",
    "test": "node tests/smoke-v7.mjs 2>&1 || echo [INFO] Smoke tests require API running at http://127.0.0.1:8787",
    "test:smoke": "node tests/smoke-v7.mjs",
    "test:smoke:rc2": "tsx tests/smoke-v7-rc2-boundaries.mjs",
    "preview": "npm --prefix apps/web-ui run preview -- --port 5173",
    "api:test": "httpyac api-tests/all-endpoints.http",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop agi-factory-api",
    "pm2:logs": "pm2 logs agi-factory-api",
    "pm2:restart": "pm2 restart agi-factory-api",
    "aip:upgrade:v7": "node scripts/aip-upgrade-v7.mjs",
    "aip:cli:build": "pnpm --dir apps/aip-cli build",
    "aip:cli:link": "pnpm --dir apps/aip-cli link --global",
    "aip:cli:doctor": "pnpm --dir apps/aip-cli dev doctor"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.1",
    "tsx": "^4.19.4"
  }
}

