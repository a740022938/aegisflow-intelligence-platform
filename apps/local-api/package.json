    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/websocket": "^11.0.2",
    "@types/uuid": "^11.0.0",
    "better-sqlite3": "^12.4.1",
    "drizzle-orm": "^0.44.2",
    "execa": "^9.1.0",
