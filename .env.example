# ===== AGI Model Factory =====
# Copy this file to .env.local and adjust paths as needed.
# Paths are relative to the project root by default.
# Do not use placeholder secrets in production.

# ===== Base Directories (auto-detected from repo root) =====
# Override only if you want data stored elsewhere.
# AIP_REPO_ROOT = <auto-detected>
# AGI_FACTORY_ROOT = <auto-detected from git root>

# ===== Service Ports =====
WEB_UI_PORT=5173
LOCAL_API_PORT=8787
WS_PORT=8788

# ===== External Services =====
OPENCLAW_BASE_URL=http://127.0.0.1:18789
DEFAULT_MODEL=gemma4

# ===== Telegram Notify (optional) =====
# Use a local HTTP proxy when Telegram API is unreachable from this network.
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890

# ===== Database =====
# SQLite DB is auto-created at packages/db/agi_factory.db
# Override SQLITE_DB_PATH only if you want it elsewhere.
# SQLITE_DB_PATH=packages/db/agi_factory.db
# SQLite tuning (advanced):
SQLITE_BUSY_TIMEOUT=5000
SQLITE_CACHE_SIZE=-64000
# SQLITE_MMAP_SIZE=0

# ===== Logging =====
LOG_LEVEL=info
# TASK_LOG_DIR  = ${AGI_AUDIT_DIR}/task_logs
# AUDIT_LOG_DIR = ${AGI_AUDIT_DIR}/audit_logs

# ===== Safety =====
ALLOW_DELETE=false
ALLOW_OVERWRITE=false
APPROVAL_REQUIRED=true

# ===== OpenClaw Security =====
# Required for /api/openclaw/heartbeat and /api/openclaw/circuit/recover
# IMPORTANT: Do NOT use these placeholder values in production.
# Generate strong tokens (e.g., openssl rand -hex 32) and set them via:
#   1. System environment variables (recommended)
#   2. .env.local (already in .gitignore)
# These placeholders will cause 401/403 errors if used as-is.
OPENCLAW_HEARTBEAT_TOKEN=replace-with-strong-token
OPENCLAW_ADMIN_TOKEN=replace-with-admin-token

# ===== Worker Pool =====
# Python Worker 持久化进程池配置
# PYTHON_WORKER_DIR=workers/python-worker
WORKER_POOL_MIN=2
WORKER_POOL_MAX=8

# ===== Task Queue =====
# 异步任务队列配置（当前为内存队列，未来可切换 BullMQ/Redis）
QUEUE_CONCURRENCY=4

# ===== OpenClaw 双向通信桥接 =====
# 自动推送工作流事件到 OpenClaw (boolean)
OPENCLAW_HEARTBEAT_V2=true
OPENCLAW_AUTO_PUSH_EVENTS=true

# ===== Authentication =====
JWT_SECRET=replace-with-local-dev-secret

# ===== PostgreSQL (optional) =====
# 设置后自动切换到 PostgreSQL，留空使用 SQLite
# DATABASE_URL=postgresql://user:pass@localhost:5432/agi_factory
PG_POOL_MIN=2
PG_POOL_MAX=10

# ===== Redis/BullMQ (optional) =====
# 设置 REDIS_HOST 后自动切换到 BullMQ，留空使用内存队列
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false

# ===== Webhook 告警 =====
# WEBHOOK_URL=https://hooks.example.com/alert
# WEBHOOK_SECRET=your-secret
